{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf .*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -ffd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-protected-branch.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "oh-my-claudecode": {
      "source": {
        "source": "github",
        "repo": "yeachan-heo/oh-my-claudecode"
      }
    }
  },
  "enabledPlugins": {
    "oh-my-claudecode@oh-my-claudecode": true
  }
}
